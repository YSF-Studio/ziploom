{
  "identifier": "default",
  "description": "Default capabilities for CollectionLoom",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "fs:allow-read-text-file",
    "fs:allow-write-text-file",
    "fs:allow-read-file",
    "fs:allow-write-file",
    "dialog:default",
    "shell:allow-open",
    "shell:allow-execute",
    "shell:allow-spawn",
    {
      "identifier": "fs:scope",
      "allow": [{ "path": "$HOME/**" }, { "path": "/mnt/**" }, { "path": "/dev/**" }, { "path": "/sys/**" }]
    }
  ]
}