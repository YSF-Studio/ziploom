{
  "$schema": "https://raw.githubusercontent.com/nicedoc/tauri/v2/schema.json",
  "productName": "CollectionLoom",
  "identifier": "com.ysf.collectionloom",
  "version": "0.1.0",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "CollectionLoom",
        "width": 1200,
        "height": 840,
        "resizable": true,
        "decorations": false,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "fs": {
      "scope": {
        "allow": [
          {
            "path": "$HOME/**"
          },
          {
            "path": "/mnt/**"
          }
        ]
      }
    },
    "shell": {
      "scope": [
        {
          "name": "run-command",
          "cmd": "bash",
          "args": true
        }
      ]
    }
  },
  "bundle": {
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}