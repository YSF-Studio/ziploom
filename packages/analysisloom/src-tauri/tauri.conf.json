{
  "$schema": "https://raw.githubusercontent.com/nicedoc/tauri/v2/schema.json",
  "productName": "AnalysisLoom",
  "identifier": "com.ysf.analysisloom",
  "version": "0.1.0",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1421",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [{ "title": "AnalysisLoom", "width": 1280, "height": 850, "resizable": true }],
    "security": { "csp": null }
  },
  "plugins": {
    "fs": { "scope": { "allow": [{ "path": "$HOME/**" }, { "path": "/mnt/**" }] } }
  }
}