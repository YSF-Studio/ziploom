{
  "$schema": "https://raw.githubusercontent.com/nicedoc/tauri/v2/schema.json",
  "productName": "AnalysisLoom",
  "identifier": "com.ysf.analysisloom",
  "version": "0.1.0",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1421",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [{
      "title": "AnalysisLoom",
      "width": 1400,
      "height": 900,
      "resizable": true,
      "decorations": false,
      "titleBarStyle": "Overlay",
      "hiddenTitle": true
    }],
    "security": { "csp": null }
  },
  "plugins": {
    "fs": { "scope": { "allow": [{ "path": "$HOME/**" }, { "path": "/mnt/**" }] } }
  },
  "bundle": {
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
